# ========================
# 1. 配置文件与机密信息 (核心重点)
# ========================
# 忽略所有包含机密信息的本地环境变量文件
.env
.env.*

# 允许提交一个脱敏的示例文件（如果有的话）
!.env.example

# (可选) 如果你连 yaml 都不想提交，可以取消注释下面这行。
# 但通常 config.*.yml 作为基础结构配置，里面没有密码，是可以提交到 Git 的。
# config.*.yml

# ========================
# 2. Python 缓存与编译文件
# ========================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
build/
dist/
wheels/
*.egg-info
.coverage
htmlcov/

# ========================
# 3. uv 及虚拟环境
# ========================
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# 注意：uv.lock 和 pyproject.toml 必须提交到 Git，不要忽略它们！

# ========================
# 4. IDE 及系统文件
# ========================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ========================
# 5. 业务日志
# ========================
logs/
*.log

# ========================
# 6. 业务数据
# ========================
data/
database/
